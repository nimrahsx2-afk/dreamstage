# DreamStage Server Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# Server Configuration
# ===========================================
NODE_ENV=development
PORT=3000

# ===========================================
# Database (PostgreSQL)
# ===========================================
# Local: postgresql://username:password@localhost:5432/dreamstage
# Render: Use the connection string from your Render PostgreSQL instance
DATABASE_URL=postgresql://postgres:password@localhost:5432/dreamstage

# ===========================================
# Authentication (JWT)
# ===========================================
# Generate a secure random string (min 32 characters)
# You can use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY=24h

# ===========================================
# CORS
# ===========================================
# Frontend URL (Vite dev server runs on 5173 by default)
CORS_ORIGIN=http://localhost:5173

# ===========================================
# Firebase Storage (Optional - for vendor PDF uploads)
# ===========================================
# Get these from Firebase Console > Project Settings > Service Accounts
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=
